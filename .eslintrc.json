{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "warn",
    "no-redeclare": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-constant-condition": "warn",
    "no-prototype-builtins": "off",
    "no-case-declarations": "warn"
  },
  "globals": {
    "THREE": "readonly",
    "FluidAudio": "readonly",
    "FluidBackground": "readonly",
    "ParticleCover": "readonly",
    "FoamSystem": "readonly",
    "FoamEqualizer": "readonly",
    "Spectrum3D": "readonly",
    "BubbleChamber": "readonly",
    "Favorites": "readonly",
    "ApiBridge": "readonly",
    "I18N": "readonly",
    "DataCache": "readonly",
    "DIYSettings": "readonly",
    "UserPanel": "readonly",
    "RendererManager": "readonly",
    "FluidSearch": "readonly",
    "FluidMusicApp": "readonly",
    "LastFM": "readonly",
    "CustomPlaylists": "readonly",
    "ModuleRegistry": "readonly",
    "showToast": "readonly",
    "__FM": "readonly",
    "fluidmusic": "readonly"
  },
  "ignorePatterns": ["public/vendor/**", "node_modules/**", "dist/**", "dist-renderer/**", "src/**"]
}
